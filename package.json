{
  "name": "launcher-odal",
  "version": "1.1.14",
  "description": "Launcher Serveur Odal",
  "main": "main.js",
  "scripts": {
    "start": "powershell -Command \"$env:ELECTRON_RUN_AS_NODE=$null; node node_modules/electron/cli.js .\"",
    "build:win": "electron-builder --win nsis --x64",
    "build:mac": "electron-builder --mac dmg",
    "build": "electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "gg.odal.launcher",
    "productName": "Odal Launcher",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "skinview3d.bundle.js",
      "background.png",
      "mods-manifest.json",
      "mods-pack/**",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Odal Launcher"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "minecraft-launcher-core": "^3.18.2",
    "minecraft-server-util": "^5.4.4",
    "msmc": "^4.1.0",
    "tar": "^7.5.19"
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "electron-winstaller@5.4.0": true
  }
}
